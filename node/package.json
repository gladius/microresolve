{
  "name": "microresolve",
  "version": "0.1.0",
  "description": "Pre-LLM decision layer: intent routing, PII detection, safety filtering, tool prefiltering. ~30μs per call, CPU-only, continuous learning.",
  "author": "Gladius Thayalarajan",
  "license": "MIT OR Apache-2.0",
  "homepage": "https://github.com/gladius/microresolve",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gladius/microresolve.git"
  },
  "bugs": {
    "url": "https://github.com/gladius/microresolve/issues"
  },
  "keywords": [
    "intent",
    "routing",
    "nlp",
    "chatbot",
    "classification"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "microresolve",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-gnu",
        "aarch64-apple-darwin"
      ]
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}
