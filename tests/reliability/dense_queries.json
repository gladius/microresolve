    { "category": "cross_provider", "query": "list stripe customers", "expected": "stripe:list_customers" },
    { "category": "cross_provider", "query": "add a customer to stripe", "expected": "stripe:create_customer" },
    { "category": "cross_provider", "query": "create order in shopify", "expected": "shopify:create_order" },
    { "category": "cross_provider", "query": "new linear project", "expected": "linear:create_project" },

    { "category": "oos", "query": "what's the weather today", "expected": null },
