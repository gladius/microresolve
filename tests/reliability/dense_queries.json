{
  "_meta": {
    "description": "Query sets for the dense-seed experiment (15 intents × 12 phrases). Dev uses similar-to-seed phrasings; validation uses deliberately different phrasings to test generalization.",
    "namespace": "bench_dense"
  },
  "dev": [
    { "category": "stripe", "query": "refund this charge", "expected": "stripe:create_refund" },
