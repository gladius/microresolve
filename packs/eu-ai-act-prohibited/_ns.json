    {"words": ["autism", "therapy"], "intent": "legitimate_use", "bonus": 2.5},
    {"words": ["mental", "health", "support"], "intent": "legitimate_use", "bonus": 2.0},

    {"_comment": "5(g) carve-outs: voluntary biometric authentication",
     "words": ["face", "unlock"], "intent": "legitimate_use", "bonus": 2.0},
    {"words": ["voluntary", "biometric"], "intent": "legitimate_use", "bonus": 2.0},
