  "policy_overrides": [
    {"_comment": "GDPR Art. 17 — explicit 'right to be forgotten' phrasing routes erasure",
     "words": ["forgotten"], "intent": "erasure_request", "bonus": 3.0},
    {"_comment": "Most common erasure phrasing — delete + account",
     "words": ["delete", "account"], "intent": "erasure_request", "bonus": 2.5},
